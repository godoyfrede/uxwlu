# ==========================================================================
# LLM (obrigatório)
# ==========================================================================
# Chave da API de inferência (Google AI Studio ou endpoint interno Magalu).
# NUNCA comite o valor real. Em produção, injete via secret manager
# (ex.: Google Secret Manager / variáveis do Cloud Run). O .env já está no
# .gitignore. Se esta chave já foi versionada em algum momento, rotacione-a.
GEMINI_API_KEY="cole_sua_chave_aqui"

# Endpoint compatível com a API OpenAI usado pelo cliente `openai`.
# Padrão (se omitido): endpoint interno de inferência do Magalu.
LLM_BASE_URL="https://api.inferencia.llm.mglu.io/v1"

# Modelos de texto e visão. Padrão (se omitido): google-gemma-4-e4b-it.
LLM_MODEL="google-gemma-4-e4b-it"
LLM_VISION_MODEL="google-gemma-4-e4b-it"

# Saída estruturada estrita (json_schema strict). Padrão false — ligue só
# depois de confirmar que o endpoint suporta. A validação em runtime já protege.
LLM_STRICT_SCHEMA="false"

# --- Embeddings / RAG (Fase 4) ---
# Nome do modelo de embedding exposto pelo endpoint. AJUSTE conforme o Magalu.
LLM_EMBEDDING_MODEL="embeddinggemma"
# Host dos embeddings. Vazio = usa o mesmo LLM_BASE_URL.
LLM_EMBEDDING_URL=""

# Modo de recuperação: "full" (injeta toda a base — padrão) ou "semantic"
# (injeta só os top-k por embedding). Ligue "semantic" após rodar
# `npm run embeddings` e confirmar o modelo de embedding.
RAG_MODE="full"
RAG_TOP_K="6"

# ==========================================================================
# Servidor
# ==========================================================================
# Porta do Express (padrão 3000).
PORT="3000"

# URL pública onde a aplicação está hospedada.
# O AI Studio / Cloud Run injeta este valor automaticamente em runtime.
APP_URL="MY_APP_URL"
